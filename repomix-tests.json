{
    "$schema": "https://repomix.com/schemas/latest/schema.json",
    "input": { "maxFileSize": 500000 },
    "output": {
        "filePath": "repomix-tests.md",
        "style": "markdown",
        "filePathStyle": "cwd-relative",
        "headerText": "Summaryception test suite. Includes all tests. Excludes docs, lockfiles, generated reports, and Repomix output.",
        "fileSummary": true,
        "directoryStructure": true,
        "files": true,
        "compress": false,
        "removeComments": false,
        "removeEmptyLines": false,
        "showLineNumbers": false,
        "topFilesLength": 10,
        "tokenCountTree": true,
        "git": { "sortByChanges": true, "includeDiffs": false, "includeLogs": false }
    },
    "include": ["tests/**/*.js"],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            "docs/**",
            "README.md",
            "LICENSE",
            ".gitignore",
            "package-lock.json",
            "coverage/**",
            "report/**",
            "repomix-*"
        ]
    },
    "security": { "enableSecurityCheck": true },
    "tokenCount": { "encoding": "o200k_base" }
}
