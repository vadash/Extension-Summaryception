#!/usr/bin/env sh

TAIL_LINES="${PRECOMMIT_ERROR_LINES:-60}"
tmp_dir="$(mktemp -d 2>/dev/null || mktemp -d -t summaryception-precommit)"
passed=''

cleanup() {
    rm -rf "$tmp_dir"
}
trap cleanup EXIT INT TERM

run_check() {
    label="$1"
    shift
    log="$tmp_dir/$label.log"

    if "$@" >"$log" 2>&1; then
        passed="${passed}${passed:+ | }$label"
        return 0
    fi

    printf 'FAIL %s\n' "$label"
    tail -n "$TAIL_LINES" "$log"
    return 1
}

run_check tsc npx tsc --noEmit --pretty false || exit 1
run_check lint-staged npx lint-staged --verbose || exit 1
run_check tests npm test || exit 1

# Run repomix asynchronously (non-blocking). Uses a lock file so concurrent
# commits queue their repomix runs instead of writing to the same files.
repomix_lock="$tmp_dir/repomix.lock"
(
    # Try to acquire lock; if held, skip (another commit is already regenerating).
    if mkdir "$repomix_lock" 2>/dev/null; then
        trap 'rmdir "$repomix_lock"' EXIT
        npm run repomix:source >/dev/null 2>&1
        npm run repomix:tests >/dev/null 2>&1
        npm run repomix:compressed-source >/dev/null 2>&1
        npm run repomix:compressed-tests >/dev/null 2>&1
    fi
) &
disown

printf 'PASS %s\n' "$passed"
