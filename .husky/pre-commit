#!/usr/bin/env sh

TAIL_LINES="${PRECOMMIT_ERROR_LINES:-60}"
tmp_dir="$(mktemp -d 2>/dev/null || mktemp -d -t summaryception-precommit)"
passed=''

cleanup() {
    rm -rf "$tmp_dir"
}
trap cleanup EXIT INT TERM

run_check() {
    label="$1"
    shift
    log="$tmp_dir/$label.log"

    if "$@" >"$log" 2>&1; then
        passed="${passed}${passed:+ | }$label"
        return 0
    fi

    printf 'FAIL %s\n' "$label"
    tail -n "$TAIL_LINES" "$log"
    return 1
}

run_check tsc npx tsc --noEmit --pretty false || exit 1
run_check lint-staged npx lint-staged --verbose || exit 1
run_check tests npm test || exit 1

# Run repomix asynchronously (fire-and-forget). A flag file acts as both
# lock and age check: no flag or flag older than 2min triggers a fresh run;
# otherwise skip. If the flag is stale (older than 2min, meaning a previous
# run likely hung), kill all repomix processes and start fresh.
repomix_flag="$tmp_dir/../summaryception-repomix.flag"
repomix_max_age=120
repomix_cmds="repomix:source repomix:tests repomix:compressed-source repomix:compressed-tests"

flag_age() {
    # Seconds since flag was last modified (works on both Linux/macOS stat)
    now=$(date +%s)
    mtime=$(stat -c %Y "$repomix_flag" 2>/dev/null || stat -f %m "$repomix_flag" 2>/dev/null)
    echo $(( now - mtime ))
}

should_run() { [ ! -f "$repomix_flag" ] || [ "$(flag_age)" -ge "$repomix_max_age" ]; }

is_stale() { [ -f "$repomix_flag" ] && [ "$(flag_age)" -ge "$repomix_max_age" ]; }

kill_stale() { pkill -f repomix 2>/dev/null; rm -f "$repomix_flag"; }

run_repomix() {
    for cmd in $repomix_cmds; do npm run "$cmd" >/dev/null 2>&1; done
    touch "$repomix_flag"
}

if should_run; then
    if is_stale; then
        kill_stale
    fi
    ( run_repomix; ) &
    disown
fi

printf 'PASS %s\n' "$passed"
