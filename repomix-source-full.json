{
    "$schema": "https://repomix.com/schemas/latest/schema.json",
    "input": { "maxFileSize": 500000 },
    "output": {
        "filePath": "repomix-source-full.md",
        "style": "markdown",
        "filePathStyle": "cwd-relative",
        "headerText": "Summaryception source modules and project automation. Includes extension root files, src modules, types, scripts, config, and project docs. Excludes tests, docs, lockfiles, generated reports, and Repomix output.",
        "fileSummary": true,
        "directoryStructure": true,
        "files": true,
        "compress": false,
        "removeComments": false,
        "removeEmptyLines": false,
        "showLineNumbers": false,
        "topFilesLength": 10,
        "tokenCountTree": true,
        "git": { "sortByChanges": true, "includeDiffs": false, "includeLogs": false }
    },
    "include": [
        "index.js",
        "manifest.json",
        "settings.html",
        "style.css",
        "src/**/*.js",
        "types/**/*.d.ts",
        "scripts/**/*.js",
        "eslint.config.js",
        "vitest.config.js",
        "tsconfig.json",
        "knip.json",
        "jscpd.json",
        "repomix-source-full.json",
        "repomix-source-compressed.json",
        "repomix-tests-full.json",
        "repomix-tests-compressed.json",
        "package.json",
        "**/AGENTS.md",
        ".prettierrc.json",
        ".prettierignore",
        ".github/workflows/**/*.yml",
        ".husky/*"
    ],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            "docs/**",
            "README.md",
            "LICENSE",
            ".gitignore",
            "package-lock.json",
            "coverage/**",
            "report/**",
            "repomix-*"
        ]
    },
    "security": { "enableSecurityCheck": true },
    "tokenCount": { "encoding": "o200k_base" }
}
